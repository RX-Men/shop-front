{
  "name": "shop-front",
  "version": "0.0.0",
  "main": "main.ts",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "deploy": "ng deploy --base-href=/shop-front/",
    "watch": "ng build --watch --configuration development",
    "tsc": "npx tsc -p tsconfig.app.json --noEmit",
    "lint": "ng lint",
    "stylelint:check": "stylelint \"src/**/*.{css,scss}\"",
    "prettier:check": "prettier --check .",
    "prettier:format": "prettier --write .",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "prepare": "husky"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@ngrx/signals": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "angular-cli-ghpages": "^3.0.3",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "validate-branch-name": "^1.3.2",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": "22.17.1",
    "npm": "10.9.2"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "bash -c 'tsc -p tsconfig.app.json --noEmit'"
    ],
    "*.scss": "stylelint --fix",
    "*": "prettier --write --ignore-unknown"
  },
  "validate-branch-name": {
    "pattern": "^(feat|chore|refactor|style|fix|docs)/[a-z0-9-]+$",
    "errorMsg": "Branch name error. Correct format: feat/login-form"
  }
}
